# ── Waddle Agent — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Note: Values in lua.skill.yaml will override values in this file.

# ── Lua API Key (optional — stored in keychain after lua auth configure) ──
# LUA_API_KEY=your-lua-api-key-here

# ── Supplier credentials ───────────────────────────────────
# One pair per supplier portal.
# The credentialsKey passed to scrape_authenticated_page is the prefix.
# e.g. credentialsKey "SUPPLIER_RS" reads SUPPLIER_RS_EMAIL + SUPPLIER_RS_PASSWORD

# RS Components Malaysia / Singapore
SUPPLIER_RS_EMAIL=your-email@example.com
SUPPLIER_RS_PASSWORD=your-password

# Element14 / Farnell
SUPPLIER_ELEMENT14_EMAIL=your-email@example.com
SUPPLIER_ELEMENT14_PASSWORD=your-password

# Add more suppliers following the same pattern:
# SUPPLIER_{KEY}_EMAIL=
# SUPPLIER_{KEY}_PASSWORD=
